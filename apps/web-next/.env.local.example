# ===========================================
# LOCAL DEVELOPMENT CONFIGURATION
# Copy to .env.local and customize as needed
# ===========================================

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/naap
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@localhost:5432/naap

# ─── App URL ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: billing-provider OAuth callbacks when the shell runs on another port
# BILLING_PROVIDER_OAUTH_CALLBACK_ORIGIN=http://localhost:3000

NEXTAUTH_SECRET=local-dev-secret-at-least-32-characters-long

# ─── Deploy Stage ───────────────────────────────────────────────────────
# Explicit deploy stage override: development | staging | production
# If not set, inferred from VERCEL_ENV or defaults to 'development'
# DEPLOY_ENV=development

# ─── OAuth SSO (optional for local dev, required for Vercel production) ─
#
# Local dev: add to THIS file (.env.local) — keep NEXT_PUBLIC_APP_URL=localhost above.
#   Google authorized redirect:  http://localhost:3000/api/v1/auth/callback/google
#   GitHub authorization callback: http://localhost:3000/api/v1/auth/callback/github
#   GOOGLE_CLIENT_ID=  GOOGLE_CLIENT_SECRET=  GITHUB_CLIENT_ID=  GITHUB_CLIENT_SECRET=
#
# ─── Vercel Production — use ONE canonical host at a time ─────────────────
# Toggle Host A/B by commenting lines: see vercel-oauth.env.template (copy from there
# into Vercel; do not merge into .env.local — duplicates NEXT_PUBLIC_APP_URL).
# In Vercel → Project → Settings → Environment Variables (Production):
#   1. Pick Host A OR Host B. Set exactly one set of URL vars (comment the other set out
#      in your notes / remove those keys from Vercel when switching).
#   2. Set GOOGLE_CLIENT_* and GITHUB_CLIENT_* (from Google Cloud + GitHub).
#   3. Match provider consoles to the SAME host (redirect URIs must equal these URLs).
#   4. Redeploy after changes.
#
# Google Cloud: https://console.cloud.google.com/apis/credentials
#   OAuth client → Authorized redirect URIs → include the Host A or B Google line below.
# GitHub: https://github.com/settings/developers → OAuth Apps
#   Authorization callback URL → exactly the Host A or B GitHub line below (one URL per app).
#
# --- Host A: https://naap-platform.vercel.app (E2E / current production preview) ---
# NEXT_PUBLIC_APP_URL=https://naap-platform.vercel.app
# GOOGLE_REDIRECT_URI=https://naap-platform.vercel.app/api/v1/auth/callback/google
# GITHUB_REDIRECT_URI=https://naap-platform.vercel.app/api/v1/auth/callback/github
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
#
# --- Host B: https://network.livepeer.org (after custom domain cutover) ---
# When switching: remove or replace Host A vars in Vercel with Host B, then in Google add
# the new redirect URI (you may keep both URIs during migration). On GitHub, change the
# OAuth App callback URL to Host B (or create a second OAuth app for the new domain).
# NEXT_PUBLIC_APP_URL=https://network.livepeer.org
# GOOGLE_REDIRECT_URI=https://network.livepeer.org/api/v1/auth/callback/google
# GITHUB_REDIRECT_URI=https://network.livepeer.org/api/v1/auth/callback/github
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
#
# E2E against production: PLAYWRIGHT_BASE_URL=https://naap-platform.vercel.app
# After cutover:        PLAYWRIGHT_BASE_URL=https://network.livepeer.org

# ─── Storage ────────────────────────────────────────────────────────────
# When BLOB_READ_WRITE_TOKEN is not set, storage falls back to local filesystem
# BLOB_READ_WRITE_TOKEN=

# ─── Email (Resend) — verification & password reset ───────────────────
# Get API key from https://resend.com/api-keys
# Without this, verification/reset links are logged to console (dev only)
# RESEND_API_KEY=
# Optional: override sender (default: NaaP Platform <onboarding@resend.dev>)
# EMAIL_FROM=NaaP <noreply@yourdomain.com>

# ─── Realtime (optional -- SSE works without Ably) ─────────────────────
# ABLY_API_KEY=

# ─── Subgraph fees proxy (server-only) ─────────────────────────────────
# Used by /api/v1/subgraph. Keep keys out of VITE_* / NEXT_PUBLIC_* vars.
# SUBGRAPH_API_KEY=
# SUBGRAPH_ID=   # optional; route may default to Livepeer mainnet (see subgraph route)

# ─── L1 RPC (protocol block / rounds tile) ─────────────────────────────
# Required for accurate protocol progress against mainnet.
# L1_RPC_URL=https://mainnet.infura.io/v3/<key>

# ─── Off-Vercel backend services (hybrid deployment) ───────────────────
# Proxied through Next.js API routes. Defaults match ./bin/start.sh local ports.

BASE_SVC_URL=http://localhost:4000
PLUGIN_SERVER_URL=http://localhost:3100

# Livepeer integration service (staking, orchestrators, protocol) -- Phase 4
# LIVEPEER_SVC_URL=http://localhost:4100

# AI/Video pipeline gateway (batch AI, live video, BYOC) -- Phase 5
# PIPELINE_GATEWAY_URL=http://localhost:4020

# Artifact storage (plugin bundles, metadata)
# STORAGE_SVC_URL=http://localhost:4050

# Infrastructure provisioning (containers, databases, ports)
# INFRASTRUCTURE_SVC_URL=http://localhost:4060

# ─── NAAP API ───────────────────────────────────────────────────────────
# Full base through the API prefix (no trailing slash).
NAAP_API_SERVER_URL=https://naap-api.livepeer.cloud/v1

# ─── Data Facade ─────────────────────────────────────────────────────────
# Set to "true" to serve hardcoded stub data for all widgets (no backends needed).
# Unset or "false" to use real data resolvers.
FACADE_USE_STUBS=true

# ─── Plugin Backend Services ────────────────────────────────────────────
# These are proxied via /api/v1/[plugin]/* catch-all route.
# Ports MUST match plugins/*/plugin.json → backend.devPort.
# CAPACITY_PLANNER_URL=http://localhost:4003
# MARKETPLACE_URL=http://localhost:4005
# COMMUNITY_URL=http://localhost:4006
# DEVELOPER_API_URL=http://localhost:4007
# WALLET_URL=http://localhost:4008
# DASHBOARD_URL=http://localhost:4009
# PLUGIN_PUBLISHER_URL=http://localhost:4010
# DAYDREAM_VIDEO_URL=http://localhost:4111

# ─── Playwright E2E (optional) ───────────────────────────────────────────
# Used by tests/auth.setup.ts and tests/auth-flows.spec.ts for logged-in journeys.
# E2E_USER_EMAIL=test@example.com
# E2E_USER_PASSWORD=your-secure-password
#
# Admin-only specs (if any reference playwright/.auth/admin.json):
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=...
#
# Target deployment. Local default matches playwright.config.ts webServer (port 3000):
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_BASE_URL=https://naap-platform.vercel.app
#
# Overview SLA hard gate (optional; default is log-only in overview-sla.spec.ts):
# E2E_ENFORCE_OVERVIEW_SLA=1
# E2E_SLA_SAMPLES=5
#
# OAuth redirect specs (tests/oauth.spec.ts):
# RUN_OAUTH_E2E=1
