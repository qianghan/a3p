  jurisdiction  String
  partnerName   String
  apiUrl        String
  apiKey        String?
  certId        String?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([jurisdiction, partnerName])
  @@schema("plugin_agentbook_tax")
}

model AbCalendarEvent {
  id              String   @id @default(uuid())
  tenantId        String
  eventType       String                        // tax_deadline | filing_deadline | invoice_due | renewal | ...
  titleKey        String                        // i18n key
  date            DateTime
  leadTimeDays    Int[]                          // [7, 3, 1, 0]
  urgency         String   @default("important")
  actionUrl       String?
  actionLabelKey  String?
  recurrence      String   @default("once")     // annual | quarterly | monthly | once
  sourceSkill     String
  sourceEntityId  String?
  status          String   @default("upcoming") // upcoming | alerted | acted_on | missed | snoozed
  createdAt       DateTime @default(now())

  @@index([tenantId, date])
  @@index([tenantId, status])
  @@schema("plugin_agentbook_core")
}

model AbEngagementLog {
  id                  String    @id @default(uuid())
  tenantId            String
  messageType         String
  category            String
  urgency             String
  sentAt              DateTime  @default(now())
  openedAt            DateTime?
  actedOnAt           DateTime?
  actionTaken         String?
  snoozed             Boolean   @default(false)
  dismissed           Boolean   @default(false)
  responseTimeSeconds Int?

  @@index([tenantId, sentAt])
  @@index([tenantId, category])
  @@schema("plugin_agentbook_core")
}

model AbTenantAccess {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  role        String   @default("viewer")        // owner | bookkeeper | viewer | cpa
  email       String
  invitedBy   String?
  accessToken String?  @unique                   // for CPA read-only link
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([accessToken])
  @@schema("plugin_agentbook_core")
}

model AbCPANote {
  id          String   @id @default(uuid())
  tenantId    String
  authorId    String
