  provider    String                            // "gemini" | "openai" | "claude" | "kimi" | "minimax"
  apiKey      String                            // encrypted in production
  baseUrl     String?
  enabled     Boolean  @default(true)
  isDefault   Boolean  @default(false)
  modelFast   String   @default("gemini-2.0-flash")
  modelStandard String @default("gemini-2.5-flash")
  modelPremium String  @default("gemini-2.5-pro")
  modelVision String?  @default("gemini-2.5-flash")
  rateLimit   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

