  lastSynced      DateTime?
  accessTokenEnc  String?                         // AES-256-GCM-encrypted Plaid access token
  cursorToken     String?                         // Plaid /transactions/sync cursor
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    AbBankTransaction[]

  @@index([tenantId])
  @@schema("plugin_agentbook_expense")
}

model AbBankTransaction {
  id                String    @id @default(uuid())
  tenantId          String
  bankAccountId     String
  bankAccount       AbBankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  plaidTransactionId String?  @unique
  amount            Int                           // cents (positive = debit/outflow, negative = credit/inflow)
  date              DateTime
  merchantName      String?
  name              String                        // transaction name/description
  category          String?                       // Plaid category
  pending           Boolean  @default(false)
  matchedExpenseId  String?                       // matched to AbExpense
  matchedInvoiceId  String?                       // matched to AbInvoice (for payments)
  matchStatus       String   @default("pending")  // pending | matched | exception | ignored
  idempotencyKey    String?  @unique              // prevent duplicate imports
  createdAt         DateTime @default(now())

  @@index([tenantId, date])
  @@index([tenantId, matchStatus])
  @@index([bankAccountId, date])
  @@schema("plugin_agentbook_expense")
}

model AbBudget {
  id            String   @id @default(uuid())
  tenantId      String
  categoryId    String?
  categoryName  String?
  amountCents   Int
  period        String   @default("monthly")
  alertPercent  Int      @default(80)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, categoryId, period])
  @@index([tenantId])
  @@schema("plugin_agentbook_expense")
}

model AbStripeWebhookEvent {
  id              String   @id @default(uuid())
  tenantId        String
  stripeEventId   String   @unique               // idempotency
  eventType       String                          // payment_intent.succeeded, charge.refunded, etc.
  processed       Boolean  @default(false)
  payload         Json
  journalEntryId  String?
  error           String?
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([stripeEventId])
  @@schema("plugin_agentbook_expense")
}

// ============================================
// PLUGIN: AGENTBOOK INVOICE
// ============================================

model AbClient {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  email           String?
  address         String?
  defaultTerms    String   @default("net-30")
  avgDaysToPay    Float?
  totalBilledCents  Int    @default(0)
  totalPaidCents    Int    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices        AbInvoice[]
  estimates       AbEstimate[]

  @@index([tenantId])
  @@schema("plugin_agentbook_invoice")
}

model AbInvoice {
  id              String   @id @default(uuid())
  tenantId        String
  clientId        String
  client          AbClient @relation(fields: [clientId], references: [id])
  number          String                        // auto-incrementing: INV-2026-0001
  amountCents     Int
  currency        String   @default("USD")      // USD | CAD | GBP | AUD | EUR
  issuedDate      DateTime
  dueDate         DateTime
  status          String   @default("draft")    // draft | sent | viewed | paid | overdue | void
  pdfUrl          String?
  pdfHtml         String?                       // stored HTML for PDF rendering
  journalEntryId  String?
  recurringId     String?                       // link to AbRecurringInvoice if auto-generated
  paymentUrl      String?
  lastRemindedAt  DateTime?
  source          String?  @default("web")      // web | telegram | api — origin of the draft
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lines           AbInvoiceLine[]
  payments        AbPayment[]
  creditNotes     AbCreditNote[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@schema("plugin_agentbook_invoice")
}

model AbInvoiceLine {
  id          String    @id @default(uuid())
  invoiceId   String
  invoice     AbInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float     @default(1)
  rateCents   Int
  amountCents Int

  @@index([invoiceId])
  @@schema("plugin_agentbook_invoice")
}

model AbPayment {
  id               String    @id @default(uuid())
  tenantId         String
  invoiceId        String?
  invoice          AbInvoice? @relation(fields: [invoiceId], references: [id])
  amountCents      Int
  method           String    @default("manual")   // manual | stripe | bank_transfer
  date             DateTime
  stripePaymentId  String?
  feesCents        Int       @default(0)
  journalEntryId   String?
  createdAt        DateTime  @default(now())

  @@index([tenantId, date])
  @@index([invoiceId])
  @@schema("plugin_agentbook_invoice")
}

model AbEstimate {
  id              String   @id @default(uuid())
  tenantId        String
  clientId        String
  client          AbClient @relation(fields: [clientId], references: [id])
  amountCents     Int
  description     String
  status          String   @default("pending")  // pending | approved | declined | expired | converted
  validUntil      DateTime
  convertedInvoiceId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@schema("plugin_agentbook_invoice")
}

model AbProject {
  id            String   @id @default(uuid())
  tenantId      String
  clientId      String?
  name          String
  description   String?
  hourlyRateCents Int?                          // null = not billable
  status        String   @default("active")     // active | completed | archived
  budgetHours   Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  timeEntries   AbTimeEntry[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, status])
  @@schema("plugin_agentbook_invoice")
}

model AbTimeEntry {
  id            String    @id @default(uuid())
  tenantId      String
  projectId     String?
  project       AbProject? @relation(fields: [projectId], references: [id])
  clientId      String?
  description   String
  startedAt     DateTime
  endedAt       DateTime?
  durationMinutes Int     @default(0)
  hourlyRateCents Int?
  billable      Boolean  @default(true)
  billed        Boolean  @default(false)
  invoiceId     String?                         // linked when auto-invoiced
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, startedAt])
  @@index([tenantId, projectId])
  @@index([tenantId, billed])
  @@index([tenantId, clientId])
  @@schema("plugin_agentbook_invoice")
}

model AbCreditNote {
  id              String   @id @default(uuid())
  tenantId        String
  invoiceId       String
  invoice         AbInvoice @relation(fields: [invoiceId], references: [id])
  number          String                        // CN-2026-0001
  amountCents     Int
  reason          String                        // reason for credit
  journalEntryId  String?
  createdAt       DateTime @default(now())

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([invoiceId])
  @@schema("plugin_agentbook_invoice")
}

model AbRecurringInvoice {
  id              String   @id @default(uuid())
  tenantId        String
  clientId        String
  currency        String   @default("USD")
  frequency       String                        // weekly | biweekly | monthly | quarterly | annual
  nextDue         DateTime
  endDate         DateTime?                     // null = no end
  status          String   @default("active")   // active | paused | completed
  templateLines   Json                          // [{description, quantity, rateCents, amountCents}]
  totalCents      Int
  daysToPay       Int      @default(30)         // net terms
  autoSend        Boolean  @default(false)      // auto-send on generation
  lastGenerated   DateTime?
  generatedCount  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([nextDue])
  @@schema("plugin_agentbook_invoice")
}

// ============================================
