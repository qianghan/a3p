{
  "name": "@naap/theme",
  "version": "0.0.1",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tailwind": {
      "types": "./src/tailwind.config.ts",
      "import": "./src/tailwind.config.ts"
    },
    "./globals.css": "./src/globals.css",
    "./shell-variables.css": {
      "import": "./src/shell-variables.css",
      "require": "./src/shell-variables.css",
      "default": "./src/shell-variables.css"
    },
    "./tailwind-extend.cjs": "./tailwind-extend.cjs"
  }
}
